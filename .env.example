#
# ShadowSeek .env Beispiel – Minimal-Konfiguration für lokalen Betrieb
#
# Pflichtfelder:
SECRET_KEY=change-me
# Niemals echte DATABASE_URL ins Repo committen, niemals im Frontend, niemals teilen!
DATABASE_URL=sqlite:///shadowseek.db
PUBLIC_BASE_URL=http://localhost:5000
APP_BASE_URL=http://localhost:5000
UPLOAD_DIRECTORY=instance/uploads
BILLING_GATING_ENABLED=true
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_OUTPUT_BUCKET=
GOOGLE_CLOUD_LOCATION=
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Stripe (optional, lokal leer lassen wenn nicht getestet)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2025-03-31.basil
STRIPE_PRICE_ID_ABO_1=
STRIPE_PRICE_ID_ABO_2=
STRIPE_PRICE_ID_ABO_3=
STRIPE_PRICE_ID_ABO_4=

# Weitere optionale Integrationen
OPENAI_API_KEY=
SERPER_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
YOUTUBE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
REDDIT_USER_AGENT=ShadowSeek/1.0 (contact: you@example.com)
