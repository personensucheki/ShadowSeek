# ---------------------------------------------------------------------------
# Google Cloud (Live/HLS Orchestrierung) – SERVERSEITIG ONLY
#
# WICHTIG:
# - Service-Account JSON ist ein SERVERSEITIGES Credential.
# - Niemals ins Repo committen.
# - Niemals ins Frontend einbauen.
# - ShadowSeek Backend liest Credentials nur zur Laufzeit (Server/Container).
# ---------------------------------------------------------------------------

# GCP Projekt für Live-Provider Orchestrierung (z.B. Live Stream API / Storage)
GOOGLE_CLOUD_PROJECT_ID=

# Region/Location (z.B. "europe-west3" oder "us-central1")
GOOGLE_CLOUD_LOCATION=

# Output Bucket für HLS (gs://<bucket-name> oder nur bucket-name je nach Provider)
GOOGLE_CLOUD_OUTPUT_BUCKET=

# Pfad zur Service-Account JSON Datei (nur serverseitig; z.B. /etc/secrets/gcp-sa.json)
# - GOOGLE_APPLICATION_CREDENTIALS verweist NUR auf den Dateipfad.
# - Niemals JSON-Inhalte, `private_key` oder `private_key_id` in .env, Chat, Issues, Uploads etc. posten.
# - `project_id` ist Metadatum (weniger kritisch), ersetzt aber KEIN Credential.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: Service Account E-Mail (für Validierung/Logging; keine Secrets)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Optional (Security): Denylist kompromittierter Credential-Files (SHA256, kommasepariert).
# Wenn der Hash eines serverseitigen Credential-Files hier gelistet ist, verweigert ShadowSeek die Provider-Nutzung.
# Beispiel: GOOGLE_COMPROMISED_CREDENTIAL_SHA256=deadbeef...,cafebabe...
GOOGLE_COMPROMISED_CREDENTIAL_SHA256=
